FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends gcc openssh-server && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml .
RUN pip install --no-cache-dir \
    fastapi>=0.115 \
    uvicorn>=0.32 \
    sqlalchemy>=2.0 \
    google-genai \
    cohere \
    chromadb>=0.5 \
    rank-bm25 \
    geopy \
    python-dateutil>=2.9

# Application code only — data lives on /data volume
COPY api/ api/
COPY pipeline/ pipeline/
COPY scraper/ scraper/

EXPOSE 8001

CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8001"]
